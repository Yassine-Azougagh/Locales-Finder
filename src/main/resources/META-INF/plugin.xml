<idea-plugin>
    <id>com.locales.locales-finder</id>
    <vendor email="yassineazougagh746@gmail.com" >Yassine</vendor>
    <version>1.0</version>
    <name>Locales-Finder</name>
    <description>
        Locales Finder helps you find your locales faster. It reads the JSON locales file recursively, extracting all keychain and their corresponding value.
        Than it organize the data in a table with search and copy capabilities, so you can work more on what matters !
    </description>
    <depends>com.intellij.modules.platform</depends>
    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Locales Extraction Window" anchor="left"
                    factoryClass="MyToolWindowFactory" icon="/static/images/window-icon.png"/>
        <notificationGroup id="Custom Notification Group"
                           displayType="BALLOON"/>
    </extensions>
    <actions>
        <action id="MyPlugin.HelloAction" class="com.locales.localesfinder.MyAction" text="Extract Locales" description="A test action" icon="/static/images/window-icon.png">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>

        </action>

    </actions>
</idea-plugin>